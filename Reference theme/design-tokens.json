{
  "$schema": "https://design-tokens.dev/schema-v1.json",
  "name": "Veyra Sounds",
  "version": "1.0.0",
  "default_theme": "midnight",

  "themes": {
    "midnight": {
      "name": "Midnight",
      "built_in": true,
      "dark": true,
      "radius_scale": 1.0,
      "animation_intensity": 1.0,
      "colors": {
        "bg-app": "#0A0B10",
        "bg-canvas": "#0F1117",
        "bg-glass": "rgba(20, 22, 32, 0.55)",
        "bg-glass-hover": "rgba(28, 30, 42, 0.65)",
        "bg-glass-active": "rgba(36, 38, 52, 0.75)",
        "bg-glass-elevated": "rgba(32, 34, 48, 0.82)",
        "bg-modal-scrim": "rgba(0, 0, 0, 0.55)",
        "bg-input": "#07080C",

        "stroke-default": "rgba(255, 255, 255, 0.08)",
        "stroke-hover": "rgba(255, 255, 255, 0.14)",
        "stroke-active": "rgba(124, 92, 255, 0.45)",
        "stroke-focus": "rgba(124, 92, 255, 0.80)",
        "stroke-light-leak": "rgba(255, 255, 255, 0.06)",

        "text-primary": "#F2F3F8",
        "text-secondary": "#A8ABBD",
        "text-tertiary": "#6B6F84",
        "text-disabled": "#4A4D5E",
        "text-on-accent": "#FFFFFF",

        "accent-primary": "#7C5CFF",
        "accent-primary-hover": "#8E72FF",
        "accent-primary-active": "#6A4AE8",
        "accent-glow": "rgba(124, 92, 255, 0.40)",
        "accent-glow-strong": "rgba(124, 92, 255, 0.65)",
        "accent-secondary": "#A8C64E",
        "accent-secondary-dim": "#86A03E",

        "success": "#4ADE80",
        "success-bg": "rgba(74, 222, 128, 0.15)",
        "warning": "#FBBF24",
        "warning-bg": "rgba(251, 191, 36, 0.15)",
        "danger": "#F87171",
        "danger-bg": "rgba(248, 113, 113, 0.15)",
        "info": "#60A5FA",
        "info-bg": "rgba(96, 165, 250, 0.15)"
      }
    },

    "pure-black": {
      "name": "Pure Black",
      "built_in": true,
      "dark": true,
      "radius_scale": 1.0,
      "animation_intensity": 1.0,
      "colors": {
        "bg-app": "#000000",
        "bg-canvas": "#050507",
        "bg-glass": "rgba(10, 10, 14, 0.65)",
        "accent-primary": "#7C5CFF",
        "text-primary": "#F2F3F8",
        "text-secondary": "#A8ABBD"
      }
    },

    "daylight": {
      "name": "Daylight",
      "built_in": true,
      "dark": false,
      "radius_scale": 1.0,
      "animation_intensity": 1.0,
      "colors": {
        "bg-app": "#F4F5F8",
        "bg-canvas": "#FFFFFF",
        "bg-glass": "rgba(255, 255, 255, 0.55)",
        "bg-glass-hover": "rgba(245, 246, 250, 0.70)",
        "bg-input": "#FAFAFC",
        "stroke-default": "rgba(0, 0, 0, 0.08)",
        "stroke-hover": "rgba(0, 0, 0, 0.14)",
        "text-primary": "#0F1117",
        "text-secondary": "#5B5F73",
        "text-tertiary": "#8A8E9F",
        "accent-primary": "#5B3FE4",
        "accent-primary-hover": "#7050EF",
        "accent-primary-active": "#4830C0"
      }
    },

    "synthwave": {
      "name": "Synthwave",
      "built_in": true,
      "dark": true,
      "colors": {
        "bg-app": "#1A0B2E",
        "bg-canvas": "#220F3D",
        "bg-glass": "rgba(40, 18, 70, 0.55)",
        "accent-primary": "#FF3CAC",
        "accent-primary-hover": "#FF55B8",
        "accent-secondary": "#784BA0"
      }
    },

    "cyberpunk": {
      "name": "Cyberpunk",
      "built_in": true,
      "dark": true,
      "colors": {
        "bg-app": "#000000",
        "bg-canvas": "#080808",
        "bg-glass": "rgba(15, 15, 15, 0.65)",
        "accent-primary": "#F0FF26",
        "accent-secondary": "#00E5FF",
        "accent-glow": "rgba(240, 255, 38, 0.60)"
      }
    },

    "forest": {
      "name": "Forest",
      "built_in": true,
      "dark": true,
      "colors": {
        "bg-app": "#0B1A0F",
        "bg-canvas": "#102216",
        "bg-glass": "rgba(20, 35, 25, 0.55)",
        "accent-primary": "#86E08A",
        "accent-glow": "rgba(134, 224, 138, 0.40)"
      }
    },

    "sunset": {
      "name": "Sunset",
      "built_in": true,
      "dark": true,
      "colors": {
        "bg-app": "#1F0E08",
        "bg-canvas": "#2B140C",
        "bg-glass": "rgba(50, 22, 14, 0.55)",
        "accent-primary": "#FF6B4A",
        "accent-secondary": "#FFA94D"
      }
    },

    "ocean": {
      "name": "Ocean",
      "built_in": true,
      "dark": true,
      "colors": {
        "bg-app": "#06181D",
        "bg-canvas": "#0A2229",
        "bg-glass": "rgba(15, 40, 50, 0.55)",
        "accent-primary": "#3FD7E4",
        "accent-glow": "rgba(63, 215, 228, 0.40)"
      }
    },

    "mono": {
      "name": "Mono",
      "built_in": true,
      "dark": true,
      "colors": {
        "bg-app": "#0A0A0A",
        "bg-canvas": "#121212",
        "bg-glass": "rgba(28, 28, 28, 0.65)",
        "accent-primary": "#FFFFFF",
        "accent-primary-hover": "#E0E0E0",
        "accent-glow": "rgba(255, 255, 255, 0.30)"
      }
    },

    "glassmorphism-max": {
      "name": "Glassmorphism Max",
      "built_in": true,
      "dark": true,
      "blur_override": 40,
      "animated_background": true,
      "colors": {
        "bg-app": "#0A0B10",
        "bg-glass": "rgba(20, 22, 32, 0.40)",
        "accent-primary": "#7C5CFF"
      }
    }
  },

  "typography": {
    "fonts": {
      "display": {
        "family": "Nasalization",
        "fallback": ["Eurostile", "Michroma", "Orbitron", "sans-serif"],
        "weight": 400,
        "case": "uppercase",
        "letter_spacing": "0.06em"
      },
      "body": {
        "family": "Inter",
        "fallback": ["SF Pro Display", "Segoe UI Variable", "system-ui", "sans-serif"],
        "weights": [400, 500, 600]
      },
      "mono": {
        "family": "JetBrains Mono",
        "fallback": ["Consolas", "monospace"],
        "weights": [400, 500],
        "tabular_numbers": true
      }
    },
    "scale": {
      "display-large":  { "font": "display", "size": 48, "weight": 400, "line_height": 48 },
      "display-medium": { "font": "display", "size": 32, "weight": 400, "line_height": 32 },
      "display-small":  { "font": "display", "size": 24, "weight": 400, "line_height": 24 },
      "display-xsmall": { "font": "display", "size": 20, "weight": 400, "line_height": 20 },
      "display-mini":   { "font": "display", "size": 16, "weight": 400, "line_height": 16 },
      "heading-h3":     { "font": "body", "size": 20, "weight": 600, "line_height": 24 },
      "heading-h4":     { "font": "body", "size": 18, "weight": 600, "line_height": 22 },
      "heading-h5":     { "font": "body", "size": 16, "weight": 600, "line_height": 20 },
      "body-large":     { "font": "body", "size": 16, "weight": 400, "line_height": 24 },
      "body":           { "font": "body", "size": 14, "weight": 400, "line_height": 20 },
      "body-small":     { "font": "body", "size": 13, "weight": 400, "line_height": 18 },
      "label":          { "font": "body", "size": 13, "weight": 500, "line_height": 16 },
      "label-small":    { "font": "body", "size": 12, "weight": 500, "line_height": 16 },
      "tooltip":        { "font": "body", "size": 12, "weight": 400, "line_height": 16 },
      "button-large":   { "font": "body", "size": 14, "weight": 600, "line_height": 20 },
      "button":         { "font": "body", "size": 13, "weight": 500, "line_height": 16 },
      "nav-label":      { "font": "body", "size": 14, "weight": 500, "line_height": 16 },
      "numeric-large":  { "font": "mono", "size": 14, "weight": 500, "line_height": 18 },
      "numeric":        { "font": "mono", "size": 13, "weight": 400, "line_height": 16 },
      "numeric-small":  { "font": "mono", "size": 11, "weight": 400, "line_height": 14 },
      "numeric-caps":   { "font": "mono", "size": 11, "weight": 700, "line_height": 16, "letter_spacing": "0.1em", "case": "uppercase" }
    }
  },

  "radii": {
    "none": 0,
    "xs": 6,
    "sm": 8,
    "md": 10,
    "lg": 16,
    "xl": 20,
    "2xl": 24,
    "pill": 999
  },

  "spacing": {
    "base": 4,
    "0": 0,
    "xs": 4,
    "sm": 8,
    "md": 12,
    "lg": 16,
    "xl": 20,
    "2xl": 24,
    "3xl": 32,
    "4xl": 40,
    "5xl": 48,
    "6xl": 64
  },

  "dimensions": {
    "window_default": { "width": 1180, "height": 760 },
    "window_min": { "width": 960, "height": 620 },
    "window_mini": { "width": 320, "height": 80 },
    "window_onboarding": { "width": 720, "height": 540 },
    "window_gamer_hud": { "width": 180, "height": 220 },
    "topbar_height": 56,
    "sidebar_expanded_width": 220,
    "sidebar_collapsed_width": 64,
    "main_canvas_padding": 24,
    "modal_widths": { "small": 480, "medium": 640, "large": 800 }
  },

  "glass": {
    "default_blur_radius": 24,
    "saturation_boost": 1.4,
    "background_refresh_interval_ms": 30000
  },

  "elevation": {
    "level-0": { "shadow": "none" },
    "level-1": { "shadow": "0 8px 32px rgba(0, 0, 0, 0.35), inset 0 1px 0 rgba(255, 255, 255, 0.06)" },
    "level-2": { "shadow": "0 12px 40px rgba(0, 0, 0, 0.45)" },
    "level-3": { "shadow": "0 16px 48px rgba(0, 0, 0, 0.55)" },
    "level-4": { "shadow": "0 24px 64px rgba(0, 0, 0, 0.65)" },
    "glow-accent": { "shadow": "0 0 24px rgba(124, 92, 255, 0.40)" },
    "glow-accent-strong": { "shadow": "0 0 32px rgba(124, 92, 255, 0.65)" },
    "glow-danger": { "shadow": "0 0 24px rgba(248, 113, 113, 0.40)" },
    "glow-success": { "shadow": "0 0 16px rgba(74, 222, 128, 0.30)" }
  },

  "animation": {
    "easing_standard": "cubic-bezier(0.32, 0.72, 0, 1)",
    "easing_decelerate": "cubic-bezier(0, 0, 0.2, 1)",
    "easing_accelerate": "cubic-bezier(0.4, 0, 1, 1)",
    "duration_instant_ms": 80,
    "duration_fast_ms": 180,
    "duration_medium_ms": 280,
    "duration_slow_ms": 400,
    "visualizer_fps": "display-refresh"
  }
}
