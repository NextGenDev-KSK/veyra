; =============================================================================
;  veyra_apo.inf  -- TEMPLATE for production hardware-targeting driver package
;
;  An APO is associated with an audio endpoint through an audio device's
;  PropertyStore (the PKEY_FX_*_EffectClsid keys). That makes a production APO
;  package an *extension INF* that targets a specific audio device by hardware
;  ID, signed and submitted to the Microsoft Hardware Dev Center.
;
;  This file is a template, NOT a drop-in installer. Replace the hardware ID
;  placeholder and sign it before use. For development, see BUILD_GUIDE.md for
;  the test-signing + regsvr32 path, which is simpler than a full driver package.
;
;  For the open-source release, VeyraSetupHelper.exe handles association via
;  the endpoint PropertyStore directly (no INF required for dev/test-signing).
; =============================================================================

[Version]
Signature   = "$WINDOWS NT$"
Class       = Extension
ClassGuid   = {e2f84ce7-8efa-411c-aa69-97454ca4cb57}
Provider    = %ProviderName%
ExtensionId = {E7C3A8F2-4B6D-4E1F-9D0A-B3C5F7E2A841}
CatalogFile = veyra_apo.cat
DriverVer   = ; set by stampinf / signing tooling
PnpLockdown = 1

[Manufacturer]
%ProviderName% = Veyra, NTamd64.10.0...19041

; Replace the empty hardware ID below with the HardwareId of the target audio
; device (e.g. HDAUDIO\FUNC_01&...). Each unique audio codec/device family that
; Veyra should attach to needs its own line here. See BUILD_GUIDE.md §2 for the
; developer test path that avoids modifying this INF.
[Veyra.NTamd64.10.0...19041]
%Veyra.DeviceDesc% = Veyra_APO_Install, ; <HardwareId of the target audio device>

[Veyra_APO_Install]
CopyFiles = Veyra_APO_CopyFiles

[Veyra_APO_CopyFiles]
veyra-apo.dll

; Associate the registered CLSID as the endpoint's mode (MFX) effect — the slot
; the audio engine reads for every endpoint type, including Bluetooth A2DP.
; The PKEY string is the VALUE NAME under the FX\0 key (standard APO INF form).
; CLSID below must match CLSID_VeyraApoEfx in dllmain.cpp.
[Veyra_APO_Install.Interfaces]
AddInterface = %KSCATEGORY_AUDIO%, , Veyra_APO_AddReg

[Veyra_APO_AddReg]
HKR,"FX\\0",%PKEY_FX_ModeEffectClsid%,,"{7E9C2B14-3F6A-4D8E-9B21-5C0A1F2E3D44}"

[SourceDisksNames]
1 = %DiskName%

[SourceDisksFiles]
veyra-apo.dll = 1

[DestinationDirs]
Veyra_APO_CopyFiles = 13 ; driver store package directory

[Strings]
ProviderName       = "Veyra Sounds"
Veyra.DeviceDesc   = "Veyra Audio Enhancer"
DiskName           = "Veyra APO Installation Media"
KSCATEGORY_AUDIO   = "{6994AD04-93EF-11D0-A3CC-00A0C9223196}"
; ED7D1D, NOT the old EC11D9 — a wrong FMTID is silently ignored by audiodg.
PKEY_FX_ModeEffectClsid = "{D04E05A6-594B-4FB6-A80D-01AF5EED7D1D},6"
